generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  nickname  String   @unique
  email     String   @unique
  password  String
  role      Role   
  createdAt DateTime @default(now())
}


