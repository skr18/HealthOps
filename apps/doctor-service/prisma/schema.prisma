generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Doctor {
  id               Int      @id @default(autoincrement())
  name             String
  specialization   String
  experience       Int
  consultationFee  Int
  rating           Float

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
